// ResolvePermissions returns ROLE_PERMISSIONS[role]. Returns an empty slice
// for unknown roles (defensive — caller code should be using the typed
// Role constants, but a runtime string from an untrusted source might not be).
func ResolvePermissions(role Role) []Permission {
	if perms, ok := ROLE_PERMISSIONS[role]; ok {
		return perms
	}
	return []Permission{}
}

// RoleHasPermission reports whether role is granted perm. Both args must be
// typed constants for the call to compile — a typo in a perm string will
// not satisfy the Permission type alias.
func RoleHasPermission(role Role, perm Permission) bool {
	for _, p := range ROLE_PERMISSIONS[role] {
		if p == perm {
		return true
		}
	}
	return false
}


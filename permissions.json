      { "name": "zeta:fines:create",      "scope": "project" },
      { "name": "zeta:fines:pay",         "scope": "project" },
      { "name": "zeta:fines:challenge",   "scope": "project" },
      { "name": "zeta:fines:assign",      "scope": "project" },
      { "name": "zeta:fleet:view",        "scope": "project" },
      { "name": "zeta:fleet:edit",        "scope": "project" },
      { "name": "zeta:drivers:view",      "scope": "project" },
      { "name": "zeta:drivers:manage",    "scope": "project" },
      { "name": "zeta:reports:view",      "scope": "project" },
      { "name": "zeta:billing:view",      "scope": "project" },
      { "name": "zeta:billing:manage",    "scope": "project" },
      { "name": "zeta:team:manage",       "scope": "project" },
      { "name": "zeta:tenant:configure",  "scope": "project" }
    ]
  },

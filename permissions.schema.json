{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/wazobiatech/permission-contract/main/permissions.schema.json",
  "title": "Nexus Permission Contract",
  "description": "Schema for permissions.json — the canonical role → permission map. Validated in CI before any contract version is tagged.",
  "type": "object",
  "required": ["version", "services", "roles", "permissions", "role_permissions"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver. Bumped on any contract change. SDKs pin to a specific version."
    },
    "description": { "type": "string" },
    "naming_convention": { "type": "string" },
    "services": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]*$"
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$"
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "uniqueItems": true,
        "items": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*:[a-z][a-z0-9_-]*:[a-z][a-z0-9_-]*$"
        }
      }
    },
    "role_permissions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["permissions"],
        "additionalProperties": false,
        "properties": {
          "inherits_from": {
            "oneOf": [
              { "type": "null" },
              { "type": "string" }
            ]
          },
          "permissions": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]*:[a-z][a-z0-9_-]*:[a-z][a-z0-9_-]*$"
            }
          }
        }
      }
    },
    "owner_only_permissions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "universal_permissions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    }
  }
}